---
import SiteLayout from "@/layouts/SiteLayout.astro";
import { marketingPage } from "@/data/marketing";
import "@/styles/global.css";

const builds = [
  {
    tag: "Proposals",
    title: "RFP Response Agent",
    reads: "RFP PDFs, amendments, Q&A, past-performance library",
    does: "Extracts L/M/C requirements with section citations, flags deadlines and missing capabilities, drafts compliance matrix",
    approves: "Requirements interpretation, assumptions, no-bid recommendations",
    outputs: "Excel · Word · Teams · SharePoint proposal folder",
    foot: ["SAM.gov ingestion", "Citation-grounded", "Human-reviewed"],
  },
  {
    tag: "Intake",
    title: "Document Intake Agent",
    reads: "Inbound emails, attachments, scanned forms, source docs",
    does: "Classifies the document, extracts structured fields with confidence scores, routes to the right queue or system",
    approves: "Low-confidence extractions and exception cases",
    outputs: "CRM · ATS · claims system · accounting software · review queue",
    foot: ["OCR + LLM", "Confidence scoring", "Exception queue"],
  },
  {
    tag: "Hiring",
    title: "Resume Screening Agent",
    reads: "Inbound resumes, the open requisition, the company's hiring rubric",
    does: "Scores candidate-job match, surfaces top N candidates with rationale, drafts initial outreach",
    approves: "The shortlist and the outreach copy before send",
    outputs: "ATS · recruiter inbox · hiring-manager Slack/Teams channel",
    foot: ["Match scoring", "Outreach drafts"],
  },
  {
    tag: "Insurance",
    title: "Claims Prep Agent",
    reads: "Claim submission, supporting documents, policy file",
    does: "Extracts loss event, identifies applicable coverage clauses, drafts initial coverage summary",
    approves: "Coverage determination, exclusions called out, response language",
    outputs: "Claims system · adjuster inbox · response template",
    foot: ["Policy-grounded", "Audit log"],
  },
  {
    tag: "Drafting",
    title: "Drafting Workbench Agent",
    reads: "Prior proposals, capability statements, the new ask, house voice guide",
    does: "Pre-drafts proposal sections, vendor letters, RFI responses in the team's voice",
    approves: "Every paragraph before it leaves",
    outputs: "Word · Google Docs · proposal template",
    foot: ["House-voice tuned", "Version diffs"],
  },
  {
    tag: "Knowledge",
    title: "Knowledge Search Agent",
    reads: "Past performance, SOPs, prior proposals, internal wiki",
    does: "Answers natural-language questions with grounded citations to source documents",
    approves: "Read-only — citation links let the user verify",
    outputs: "Slack · Teams · lightweight web search UI",
    foot: ["RAG with citations", "SSO"],
  },
];

const integrationChips = [
  "Outlook", "Gmail", "Slack", "Teams", "SharePoint", "Drive",
  "Excel / Sheets", "HubSpot", "Salesforce", "ATS", "SAM.gov", "Word",
];

const segments = [
  { num: "01", title: "Federal-adjacent ops & proposal teams", body: "RFPs, SOWs, compliance matrices, capability statements, past performance. We bring the document-AI layer; we don't pretend to be capture strategists.", weight: "Primary", primary: true },
  { num: "02", title: "Proposal & capture consultants", body: "Direct buyers and partner channel. They own the capture domain; we build the workflow layer.", weight: "Primary", primary: true },
  { num: "03", title: "Staffing & recruiting", body: "Resume intake, candidate-job matching, compliance packets, client submissions.", weight: "Testing", primary: false },
  { num: "04", title: "Regional insurance", body: "Claims intake, document extraction, renewal prep, response drafting.", weight: "Testing", primary: false },
  { num: "05", title: "CPA & accounting", body: "Document intake, source doc extraction, working papers, client comms.", weight: "Testing", primary: false },
  { num: "06", title: "Construction back-office", body: "Submittals, RFIs, change orders, vendor docs.", weight: "Warm intro", primary: false },
];

const segmentsSystems = [
  "OmniBid — RFP parser",
  "Atlas Outbound",
  "Mesh Mind",
  "Civicly — Legislative RAG",
  "TeachMagic",
  "Acadiana Web Design",
  "FoodTruckFlow",
];

const proofStats = [
  { numHtml: '1<span class="suffix">st</span>', h: "Hackathon win", p: "Atlas Outbound — first place, $10K at the Convex Modern Stack Hackathon." },
  { numHtml: "08", h: "Production systems", p: "OmniBid, Atlas, Mesh Mind, Civicly, TeachMagic, AWD, FoodTruckFlow." },
  { numHtml: "DOL", h: "Federal contract, active", p: "Full-stack engineer on a Department of Labor contract. Veteran-owned." },
  { numHtml: '72<span class="suffix">reqs</span>', h: "Parsed per RFP, with citations", p: "OmniBid shreds 70+ requirements per solicitation in under five seconds, with citations." },
];

const marqueeItems = [
  "GovCon", "Proposal & Capture", "Staffing & Recruiting",
  "Regional Insurance", "CPA & Accounting", "Construction Back-Office",
  "Document-Heavy Teams",
];

const pipelineNodes = [
  { name: "Ingest", sub: "47 docs", iconKey: "doc" },
  { name: "Extract", sub: "Gemini", iconKey: "scan" },
  { name: "Review", sub: "Human", iconKey: "eye" },
  { name: "Export", sub: "Sheets", iconKey: "send" },
];

const activities = [
  { time: "now", text: "RFP-2026-0421 — 72 requirements extracted", tag: "shipped", warn: false },
  { time: "2m", text: "Claim #84021 — assigned to review queue", tag: "review", warn: true },
  { time: "8m", text: "Resume batch — 24 candidates matched", tag: "shipped", warn: false },
  { time: "14m", text: "SOW v3 — past-performance citations updated", tag: "shipped", warn: false },
];

const timelineSteps = [
  { day: "Day 01 — Kickoff", h: "Confirm scope", p: "One workflow, decision-maker, 2–4 stakeholders, sample documents." },
  { day: "Days 02–04 — Discovery", h: "Observe the actual work", p: "Not what they say they do — what they do. Map triggers, handoffs, time per cycle." },
  { day: "Days 04–07 — Build", h: "Working prototype", p: "Upload → process → review → export. Citations, confidence scores, audit log." },
  { day: "Days 08–09 — Memo", h: "Roadmap and ROI", p: "Buy, build, or integrate recommendation, 90-day plan, retainer proposal." },
  { day: "Day 10 — Delivery", h: "Live demo and training", p: "Recorded 60-min training. Retainer handed over with 14-day credit window." },
];

const heroChips = [
  { glyph: "SG", label: "SAM.gov", sub: "RFPs", cls: "c1" },
  { glyph: "DR", label: "Google Drive", sub: "Docs", cls: "c2" },
  { glyph: "SP", label: "SharePoint", sub: "Intake", cls: "c3" },
  { glyph: "XL", label: "Excel / Sheets", sub: "Export", cls: "c4" },
];
---

<SiteLayout title={marketingPage.title} description={marketingPage.description}>
  <!-- Nav -->
  <header class="nav" id="site-nav">
    <div class="container nav-row">
      <a href="#top" class="brand">
        <span class="brand-mark">V</span>
        <span>Varholdt AI</span>
      </a>
      <nav class="nav-links">
        <a href="#what">Agents</a>
        <a href="#how">Process</a>
        <a href="#proof">Proof</a>
        <a class="btn btn-primary" href="#book">
          Book a free audit
          <svg class="btn-arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 8h10M9 4l4 4-4 4"></path>
          </svg>
        </a>
      </nav>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section id="top" class="hero" data-hero>
      <div class="hero-bg" aria-hidden="true">
        <div class="hero-bg-grid"></div>
        <div class="hero-bg-glow"></div>
        <div class="hero-bg-fade"></div>
      </div>

      <div class="hero-chips" aria-hidden="true">
        {heroChips.map((c) => (
          <span class={`hero-chip ${c.cls}`}>
            <span class="glyph">{c.glyph}</span>
            {c.label}
            <span class="sub">{c.sub}</span>
          </span>
        ))}
      </div>

      <div class="container hero-inner">
        <h1 class="hero-headline">
          <span class="line"><span>Install AI workflow agents</span></span>
          <span class="line"><span>without hiring an <em>AI team.</em></span></span>
        </h1>

        <p class="hero-sub">
          Human-reviewed agents that read your documents, draft and route the
          predictable work, and live in the tools your team already uses —
          <strong>Outlook, Slack, Teams, SharePoint, your CRM.</strong> Not
          another app.
        </p>

        <div class="hero-actions">
          <a class="btn btn-primary" href="#book">
            Book a free 30-min audit
            <svg class="btn-arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 8h10M9 4l4 4-4 4"></path>
            </svg>
          </a>
          <a class="btn btn-ghost" href="#loom">Watch the 2-min demo</a>
        </div>

        <div class="hero-meta">
          <span><span class="tick"></span> Free 30-min workflow audit</span>
          <span><span class="tick"></span> $5K paid sprint, credits to retainer</span>
          <span><span class="tick"></span> 2 founding spots open</span>
        </div>

        <div class="hero-demo-wrap">
          <div class="hero-demo">
            <!-- Demo dashboard -->
            <div class="demo">
              <div class="demo-head">
                <div class="demo-head-left">
                  <span class="demo-head-title">RFP Shred</span>
                  <span class="demo-head-crumb">Sprint · Day 6 of 10</span>
                </div>
                <div class="demo-head-right">
                  <span class="demo-tab active">Workflows</span>
                  <span class="demo-tab">Documents</span>
                  <span class="demo-tab">Reports</span>
                </div>
              </div>

              <div class="demo-body">
                <aside class="demo-sidebar">
                  <div class="demo-sidebar-label">Active</div>
                  <div class="demo-sidebar-item active">
                    <span class="si-dot"></span> RFP Shred
                    <span class="si-count">12</span>
                  </div>
                  <div class="demo-sidebar-item">
                    <span class="si-dot"></span> Claims Intake
                    <span class="si-count">47</span>
                  </div>
                  <div class="demo-sidebar-item">
                    <span class="si-dot"></span> Resume Match
                    <span class="si-count">8</span>
                  </div>
                  <div class="demo-sidebar-item">
                    <span class="si-dot"></span> Knowledge Search
                    <span class="si-count">—</span>
                  </div>
                  <div class="demo-sidebar-label" style="margin-top: 22px;">Archive</div>
                  <div class="demo-sidebar-item">
                    <span class="si-dot"></span> Submittals
                  </div>
                  <div class="demo-sidebar-item">
                    <span class="si-dot"></span> Drafting Bench
                  </div>
                </aside>

                <div class="demo-main">
                  <div class="demo-main-head">
                    <h4>RFP Shred — federal solicitation parser</h4>
                    <span class="meta">847 docs · live</span>
                  </div>

                  <div class="demo-kpis">
                    <div class="demo-kpi">
                      <div class="k">Docs processed</div>
                      <div class="v" data-ticker data-target="847">0</div>
                      <div class="delta">↑ 12% this week</div>
                    </div>
                    <div class="demo-kpi">
                      <div class="k">Avg parse time</div>
                      <div class="v">4.2<span class="unit">s</span></div>
                      <div class="delta">↓ 0.8s</div>
                    </div>
                    <div class="demo-kpi">
                      <div class="k">Hours saved</div>
                      <div class="v" data-ticker data-target="184">0</div>
                      <div class="delta">vs. manual</div>
                    </div>
                    <div class="demo-kpi">
                      <div class="k">Review queue</div>
                      <div class="v">3</div>
                      <div class="delta warn">awaiting human</div>
                    </div>
                  </div>

                  <div class="demo-pipeline">
                    <div class="demo-pipeline-head">
                      <span class="t">Active pipeline</span>
                      <span class="right"><span class="dot"></span> Live · 4 stages</span>
                    </div>
                    <div class="demo-flow" data-pipeline>
                      {pipelineNodes.map((n, i) => (
                        <>
                          <div class="demo-node" data-node-idx={i}>
                            <span class="icon">
                              {n.iconKey === "doc" && (
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                  <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8l-5-5z"></path>
                                  <path d="M14 3v5h5M9 13h6M9 17h6"></path>
                                </svg>
                              )}
                              {n.iconKey === "scan" && (
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                  <path d="M4 8V5a1 1 0 0 1 1-1h3M16 4h3a1 1 0 0 1 1 1v3M20 16v3a1 1 0 0 1-1 1h-3M8 20H5a1 1 0 0 1-1-1v-3"></path>
                                  <path d="M4 12h16"></path>
                                </svg>
                              )}
                              {n.iconKey === "eye" && (
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                  <path d="M1.5 12s4-7 10.5-7 10.5 7 10.5 7-4 7-10.5 7S1.5 12 1.5 12z"></path>
                                  <circle cx="12" cy="12" r="3"></circle>
                                </svg>
                              )}
                              {n.iconKey === "send" && (
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                  <path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"></path>
                                </svg>
                              )}
                            </span>
                            <div class="name">{n.name}</div>
                            <div class="sub">{n.sub}</div>
                          </div>
                          {i < pipelineNodes.length - 1 && <div class="demo-arrow-track"></div>}
                        </>
                      ))}
                    </div>
                    <div class="demo-activity">
                      {activities.map((a) => (
                        <div class="demo-activity-row">
                          <span class="time">{a.time}</span>
                          <span class="text">{a.text}</span>
                          <span class={`pill ${a.warn ? "warn" : ""}`}>{a.tag}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Marquee -->
    <div class="marquee-section" aria-hidden="true">
      <div class="marquee-track">
        {[0, 1].map(() => (
          <>
            {marqueeItems.map((t) => (
              <span class="marquee-item">
                <span class="glyph"></span>
                {t}
              </span>
            ))}
          </>
        ))}
      </div>
    </div>

    <!-- Intro -->
    <section class="section" id="intro">
      <div class="container">
        <div class="section-head">
          <div class="kicker-row"><span class="kicker">01 — Thesis</span></div>
          <h2 class="section-title">Find the workflow <em>worth automating.</em></h2>
          <p class="section-lede">
            Hiring a full-time AI engineer is a $180K bet with no guarantee of ROI.
            Generic SaaS solves the easy 30% and leaves the messy middle. We're the
            third option — a senior operator embedded for six months.
          </p>
        </div>
        <div class="intro-grid">
          <p class="intro-statement">
            Most teams know AI matters. They don't know <em>which workflow</em>
            to start with — or where the agent should actually live so the team
            will use it. We find both, ship it, train the team, keep it running.
          </p>
          <div class="intro-points">
            <div class="intro-point reveal">
              <div class="num">01</div>
              <div>
                <h4>Lives in the tools you already use.</h4>
                <p>Outlook, Slack, Teams, SharePoint, Drive, your CRM, your ATS. A lightweight review UI only where control specifically requires one.</p>
              </div>
            </div>
            <div class="intro-point reveal" data-delay="1">
              <div class="num">02</div>
              <div>
                <h4>Buy, build, or integrate — honest answer.</h4>
                <p>Sometimes the right answer is a $99/mo SaaS tool we configure for you. We'll tell you when that's the case.</p>
              </div>
            </div>
            <div class="intro-point reveal" data-delay="2">
              <div class="num">03</div>
              <div>
                <h4>Human review stays in the loop.</h4>
                <p>Decision-support, not autonomous high-stakes decisions. Audit logs, citations, confidence scores on every agent.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Loom -->
    <section class="section" id="loom" style="padding-top: 0;">
      <div class="container">
        <div class="section-head">
          <div class="kicker-row"><span class="kicker">02 — Proof, on film</span></div>
          <h2 class="section-title">Watch a real federal RFP get parsed in <em>under five seconds.</em></h2>
          <p class="section-lede">
            Two minutes. One real public RFP from SAM.gov. Ingested, requirements extracted with citations,
            compliance matrix generated. The same engine ships inside our retainer engagements.
          </p>
        </div>

        <div class="loom-frame reveal">
          <div class="loom-meta">
            <span class="red"></span>
            Loom · 02:14 · OmniBid walkthrough
          </div>
          <div class="loom-overlay">
            <button class="loom-play" aria-label="Play demo">
              <svg width="30" height="30" viewBox="0 0 24 24" fill="currentColor">
                <path d="M8 5.14v13.72L19 12 8 5.14z"></path>
              </svg>
            </button>
          </div>
          <div class="loom-corner">Placeholder — embed Loom here</div>
        </div>

        <div class="loom-caption">
          <span>00:00 Intro &nbsp;·&nbsp; 00:15 What Varholdt AI does &nbsp;·&nbsp; 00:30 OmniBid live</span>
          <span>Hosted on Loom &nbsp;·&nbsp; CC available</span>
        </div>
      </div>
    </section>

    <!-- What we build — the agents -->
    <section class="section" id="what">
      <div class="container">
        <div class="section-head">
          <div class="kicker-row"><span class="kicker">03 — The agents</span></div>
          <h2 class="section-title">Six agents we ship <em>over and over.</em></h2>
          <p class="section-lede">
            Each one reads what it should read, does what it should do, hands off
            to a human at the decision point, and writes the result back to the
            tool you already use. We ship one in your sprint, then expand. One at
            a time. No parallel scope creep.
          </p>
        </div>

        <div class="builds">
          {builds.map((b, i) => (
            <article class="build reveal" data-delay={(i % 4).toString()}>
              <div class="build-head">
                <span class="build-num">0{i + 1}  ·  0{builds.length}</span>
                <span class="build-tag">{b.tag}</span>
              </div>
              <h3>{b.title}</h3>
              <dl class="build-spec">
                <div class="build-spec-row">
                  <dt>Reads</dt>
                  <dd>{b.reads}</dd>
                </div>
                <div class="build-spec-row">
                  <dt>Does</dt>
                  <dd>{b.does}</dd>
                </div>
                <div class="build-spec-row">
                  <dt>Human approves</dt>
                  <dd>{b.approves}</dd>
                </div>
                <div class="build-spec-row">
                  <dt>Outputs to</dt>
                  <dd>{b.outputs}</dd>
                </div>
              </dl>
              <div class="build-foot">
                {b.foot.map((f) => <span>{f}</span>)}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Integrations strip -->
    <section class="section integrations-section" id="integrations" style="padding-top: 0;">
      <div class="container">
        <div class="section-head">
          <div class="kicker-row"><span class="kicker">03b — Lives in your tools</span></div>
          <h2 class="section-title">No new app. <em>Your tools.</em></h2>
          <p class="section-lede">
            We build the workflow around the tools your team already uses. A
            lightweight review UI only where control specifically requires one —
            confidence highlighting, audit log, citation links. Every sprint has
            one primary interface and one export destination. No Zapier in a
            trench coat.
          </p>
        </div>

        <div class="integration-chips reveal">
          {integrationChips.map((t) => (
            <span class="integration-chip">{t}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- Who it's for -->
    <section class="section" id="who" style="padding-top: 0;">
      <div class="container">
        <div class="section-head">
          <div class="kicker-row"><span class="kicker">04 — Who it's for</span></div>
          <h2 class="section-title">Built for document-heavy teams.</h2>
          <p class="section-lede">
            20–250 person teams with recurring document and email volume, a workflow owner with authority,
            a decision-maker who can sign inside 30 days, and tried-SaaS-but-the-messy-middle-remains energy.
          </p>
        </div>

        <div class="segments">
          {segments.map((s, i) => (
            <div class="segment reveal" data-delay={(i % 4).toString()}>
              <span class="segment-num">{s.num}</span>
              <div>
                <h4>{s.title}</h4>
                <p>{s.body}</p>
              </div>
              <span class={`segment-weight ${s.primary ? "primary" : ""}`}>{s.weight}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="section" id="how">
      <div class="container">
        <div class="section-head">
          <div class="kicker-row"><span class="kicker">05 — How it works</span></div>
          <h2 class="section-title">Free audit, paid sprint, then we get to <em>work.</em></h2>
          <p class="section-lede">
            Three steps. Start with a free 30-minute audit — we walk one workflow you actually do every
            week and I tell you whether it's automatable, whether SaaS already solves it, or where the
            real leverage is. If it's a fit, the paid sprint produces a real prototype. If it isn't, you
            owe me nothing and you've still got a clearer head about the problem.
          </p>
        </div>

        <div class="how-audit reveal">
          <div class="how-audit-left">
            <div class="how-step"><span class="num">0</span> Free</div>
            <h3>30-minute AI Workflow Audit</h3>
            <p>
              One workflow, 30 minutes, verbal feedback. No deck, no deliverable,
              no obligation. We figure out together whether there's a real
              opportunity worth a paid sprint — or whether the right answer is a
              SaaS tool, a process change, or doing nothing.
            </p>
          </div>
          <a class="btn btn-primary how-audit-cta" href="#book">
            Book the audit
            <svg class="btn-arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 8h10M9 4l4 4-4 4"></path>
            </svg>
          </a>
        </div>

        <div class="how">
          <div class="how-card how-sprint reveal">
            <div class="how-step"><span class="num">1</span> Paid proof</div>
            <h3>AI Workflow Sprint</h3>
            <div class="how-price">
              <span class="amt">$5,000</span>
              <span class="per">flat — 10 business days</span>
            </div>
            <ul class="how-list">
              <li>
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 8.5l3 3 7-7.5"></path>
                </svg>
                <span><strong>Current-state map</strong> of one document-heavy workflow with stakeholder interviews</span>
              </li>
              <li>
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 8.5l3 3 7-7.5"></path>
                </svg>
                <span><strong>Working prototype</strong> of the highest-leverage slice — live, demo-able, not slideware</span>
              </li>
              <li>
                <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 8.5l3 3 7-7.5"></path>
                </svg>
