---
import SiteLayout from "@/layouts/SiteLayout.astro";
import { marketingPage } from "@/data/marketing";
import "@/styles/global.css";

const builds = [
  {
    kind: "intake",
    tag: "Intake",
    title: "Document Intake Agent",
    reads: "Inbound emails, attachments, scanned forms, source docs",
    does: "Classifies the document, extracts structured fields with confidence scores, routes to the right queue or system",
    approves: "Low-confidence extractions and exception cases",
    outputs: "CRM · ATS · claims system · accounting software · review queue",
    foot: ["Confidence-scored", "Exception routing"],
  },
  {
    kind: "rfp",
    tag: "Proposals",
    title: "RFP Response Agent",
    reads: "RFP PDFs, amendments, Q&A, past-performance library",
    does: "Extracts L/M/C requirements with section citations, flags deadlines and missing capabilities, drafts compliance matrix",
    approves: "Requirements interpretation, assumptions, no-bid recommendations",
    outputs: "Excel · Word · Teams · SharePoint proposal folder",
    foot: ["SAM.gov ingestion", "Citation-grounded", "Human-reviewed"],
  },
  {
    kind: "resume",
    tag: "Hiring",
    title: "Resume Screening Agent",
    reads: "Inbound resumes, the open requisition, the company's hiring rubric",
    does: "Scores candidate-job match, surfaces top N candidates with rationale, drafts initial outreach",
    approves: "The shortlist and the outreach copy before send",
    outputs: "ATS · recruiter inbox · hiring-manager Slack/Teams channel",
    foot: ["Match scoring", "Outreach drafts"],
  },
  {
    kind: "claims",
    tag: "Insurance",
    title: "Claims Prep Agent",
    reads: "Claim submission, supporting documents, policy file",
    does: "Extracts loss event, identifies applicable coverage clauses, drafts initial coverage summary",
    approves: "Coverage determination, exclusions called out, response language",
    outputs: "Claims system · adjuster inbox · response template",
    foot: ["Policy-grounded", "Audit log"],
  },
];

const integrationChips = [
  { name: "Slack", icon: "https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/slack.svg" },
  { name: "Teams", icon: "https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/microsoftteams.svg" },
  { name: "Outlook", icon: "https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/microsoftoutlook.svg" },
  { name: "Gmail", icon: "https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/gmail.svg" },
  { name: "SharePoint", icon: "https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/microsoftsharepoint.svg" },
  { name: "Google Drive", icon: "https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/googledrive.svg" },
  { name: "Excel", icon: "https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/microsoftexcel.svg" },
  { name: "Sheets", icon: "https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/googlesheets.svg" },
  { name: "HubSpot", icon: "https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/hubspot.svg" },
  { name: "Salesforce", icon: "https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/salesforce.svg" },
  { name: "Greenhouse / ATS", icon: "https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/greenhouse.svg" },
  { name: "Word", icon: "https://cdn.jsdelivr.net/npm/simple-icons@latest/icons/microsoftword.svg" },
];

const segments = [
  { num: "01", title: "Federal-adjacent ops & proposal teams", body: "RFPs, SOWs, compliance matrices, capability statements, past performance. We bring the document-AI layer; we don't pretend to be capture strategists." },
  { num: "02", title: "Proposal & capture consultants", body: "Direct buyers and partner channel. They own the capture domain; we build the workflow layer." },
  { num: "03", title: "Staffing & recruiting", body: "Resume intake, candidate-job matching, compliance packets, client submissions." },
  { num: "04", title: "Regional insurance", body: "Claims intake, document extraction, renewal prep, response drafting." },
  { num: "05", title: "CPA & accounting", body: "Document intake, source doc extraction, working papers, client comms." },
  { num: "06", title: "Construction back-office", body: "Submittals, RFIs, change orders, vendor docs." },
];

const proofStats = [
  { numHtml: '1<span class="suffix">st</span>', h: "Hackathon win", p: "Atlas Outbound — first place, $10K at the Convex Modern Stack Hackathon." },
  { numHtml: "08", h: "Production systems", p: "OmniBid, Atlas, Mesh Mind, Civicly, TeachMagic, AWD, FoodTruckFlow." },
  { numHtml: "DOL", h: "Federal contract, active", p: "Full-stack engineer on a Department of Labor contract. Veteran-owned." },
];

const timelineSteps = [
  { day: "Day 01 — Kickoff", h: "Confirm scope", p: "One workflow, decision-maker, 2–4 stakeholders, sample documents." },
  { day: "Days 02–04 — Discovery", h: "Observe the actual work", p: "Not what they say they do — what they do. Map triggers, handoffs, time per cycle." },
  { day: "Days 04–07 — Build", h: "Working prototype", p: "Upload → process → review → export. Citations, confidence scores, audit log." },
  { day: "Days 08–09 — Memo", h: "Roadmap and ROI", p: "Buy, build, or integrate recommendation, 90-day plan, retainer proposal." },
  { day: "Day 10 — Delivery", h: "Live demo and training", p: "Recorded 60-min training. Retainer handed over with 14-day credit window." },
];

const heroChips = [
  { key: "chatgpt", label: "ChatGPT", cls: "c1" },
  { key: "claude", label: "Claude", cls: "c2" },
  { key: "drive", label: "Google Drive", cls: "c3" },
  { key: "sheets", label: "Sheets", cls: "c4" },
];


// Sprint-selection scoreboard — five candidate workflows scored on
// volume × repeatability × ROI; highest combined score wins the sprint.
const pickCandidates = [
  { name: "RFP intake",             vol: 0.80, rep: 0.85, roi: 0.95, score: 6.5, winner: true  },
  { name: "Claims intake",          vol: 0.78, rep: 0.82, roi: 0.88, score: 5.6, winner: false },
  { name: "Resume screening",       vol: 0.72, rep: 0.78, roi: 0.82, score: 4.6, winner: false },
  { name: "Expense classification", vol: 0.50, rep: 0.60, roi: 0.50, score: 1.5, winner: false },
  { name: "Email triage",           vol: 0.85, rep: 0.35, roi: 0.40, score: 1.2, winner: false },
];

---

<SiteLayout title={marketingPage.title} description={marketingPage.description}>
  <!-- Nav -->
  <header class="nav" id="site-nav">
    <div class="container nav-row">
      <a href="/" class="brand">
        <span>Varholdt AI</span>
      </a>
      <nav class="nav-links">
        <a class="btn btn-primary" href="#book">
          Book a free audit
          <svg class="btn-arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 8h10M9 4l4 4-4 4"></path>
          </svg>
        </a>
      </nav>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section id="top" class="hero" data-hero>
      <div class="hero-bg" aria-hidden="true">
        <div class="hero-bg-grid"></div>
        <div class="hero-bg-glow"></div>
        <div class="hero-bg-fade"></div>
      </div>

      <div class="hero-chips" aria-hidden="true">
        {heroChips.map((c) => (
          <span class={`hero-chip ${c.cls}`} data-icon={c.key} title={c.label}>
            {c.key === "chatgpt" && (
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path fill="#ffffff" d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.91 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a5.985 5.985 0 0 0-3.998 2.9 6.046 6.046 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.997-2.9 6.056 6.056 0 0 0-.747-7.073zm-9.022 12.6a4.479 4.479 0 0 1-2.876-1.04l.141-.081 4.779-2.758a.795.795 0 0 0 .392-.681v-6.737l2.02 1.168a.071.071 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494zM3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.759a.771.771 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646zM2.34 7.896a4.485 4.485 0 0 1 2.366-1.973V11.6a.766.766 0 0 0 .388.676l5.815 3.355-2.02 1.168a.076.076 0 0 1-.071 0l-4.83-2.786A4.504 4.504 0 0 1 2.34 7.872zm16.597 3.855-5.833-3.387L15.119 7.2a.076.076 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.407-.667zm2.01-3.023-.141-.085-4.774-2.782a.776.776 0 0 0-.785 0L9.409 9.23V6.897a.066.066 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zm-12.64 4.135-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08L8.704 5.46a.795.795 0 0 0-.393.681zm1.097-2.365 2.602-1.5 2.607 1.5v2.999l-2.597 1.5-2.607-1.5z"/>
              </svg>
            )}
            {c.key === "claude" && (
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path fill="#D97757" d="M4.709 15.955l4.72-2.647.079-.23-.079-.128h-.23l-.79-.048-2.695-.073-2.337-.097-2.266-.122-.571-.121L0 11.784l.055-.352.48-.321.686.06 1.52.103 2.278.158 1.652.097 2.449.255h.389l.055-.157-.134-.098-.103-.097-2.358-1.596-2.552-1.688-1.336-.972-.724-.491-.364-.462-.158-1.008.656-.722.881.06.225.061.893.686 1.908 1.476 2.491 1.833.365.304.146-.103.018-.073-.164-.274-1.355-2.45-1.446-2.49-.644-1.032-.17-.619a2.97 2.97 0 01-.104-.729L6.283.134 6.696 0l.996.134.42.364.62 1.414 1.002 2.229 1.555 3.03.456.898.243.832.091.255h.158V9.01l.128-1.706.237-2.095.23-2.695.08-.76.376-.91.747-.492.584.28.48.685-.067.444-.286 1.851-.559 2.903-.364 1.942h.212l.243-.243.985-1.306 1.652-2.064.73-.82.85-.904.547-.431h1.033l.76 1.129-.34 1.166-1.064 1.347-.881 1.142-1.264 1.7-.79 1.36.073.11.188-.02 2.856-.606 1.543-.28 1.842-.315.833.388.091.395-.328.807-1.969.486-2.309.462-3.439.813-.042.03.049.061 1.549.146.662.036h1.622l3.02.225.79.522.474.638-.079.485-1.215.62-1.64-.389-3.829-.91-1.312-.329h-.182v.11l1.093 1.068 2.006 1.81 2.509 2.33.127.578-.322.455-.34-.049-2.205-1.657-.851-.747-1.926-1.62h-.128v.17l.444.649 2.345 3.521.122 1.08-.17.353-.608.213-.668-.122-1.374-1.925-1.415-2.167-1.143-1.943-.14.08-.674 7.254-.316.37-.729.28-.607-.461-.322-.747.322-1.476.389-1.924.315-1.53.286-1.9.17-.632-.012-.042-.14.018-1.439 1.974-2.187 2.955-1.732 1.854-.414.165-.717-.37.067-.662.401-.589 2.388-3.036 1.44-1.882.929-1.086-.006-.158h-.055L4.132 18.56l-1.122.146-.481-.452.06-.74.231-.243 1.908-1.312-.019.006z"/>
              </svg>
            )}
            {c.key === "drive" && (
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path fill="#0066DA" d="M1.612 19.092L2.95 21.404a3.111 3.111 0 0 0 1.13 1.13l4.776-8.27H0c0 .532.138 1.06.404 1.522z"/>
                <path fill="#00AC47" d="M12 6.131L7.224 0a3.111 3.111 0 0 0-1.13 1.13L.404 11.062A3.066 3.066 0 0 0 0 12.262h8.856L12 6.131z"/>
                <path fill="#EA4335" d="M19.92 22.534a3.111 3.111 0 0 0 1.13-1.13l.556-.95L24 16.534a3.066 3.066 0 0 0 .404-1.522H15.55l1.884 3.7 2.486 3.822z"/>
                <path fill="#00832D" d="M12 6.131L16.776 0a3.066 3.066 0 0 0-1.522-.404H8.746A3.066 3.066 0 0 0 7.224 0L12 6.131z"/>
                <path fill="#2684FC" d="M15.55 15.012H8.45L4.08 22.534c.462.266.99.404 1.522.404h12.796c.532 0 1.06-.138 1.522-.404l-4.37-7.522z"/>
                <path fill="#FFBA00" d="M19.868 6.61L16.97 1.13A3.111 3.111 0 0 0 15.84 0L12 6.131l3.55 6.13h8.84a3.066 3.066 0 0 0-.404-1.521l-4.118-4.13z"/>
              </svg>
            )}
            {c.key === "sheets" && (
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path fill="#0F9D58" d="M14.25 0H3.75A1.5 1.5 0 0 0 2.25 1.5v21A1.5 1.5 0 0 0 3.75 24h16.5a1.5 1.5 0 0 0 1.5-1.5V7.5L14.25 0z"/>
                <path fill="#0C7F43" d="M14.25 0v6a1.5 1.5 0 0 0 1.5 1.5h6L14.25 0z"/>
                <path fill="#FFF" d="M16.5 18.75h-9v-7.5h9v7.5zm-7.5-1.5h2.25v-1.5H9v1.5zm0-3h2.25v-1.5H9v1.5zm3.75 3H15v-1.5h-2.25v1.5zm0-3H15v-1.5h-2.25v1.5z"/>
              </svg>
            )}
            <span class="hero-chip-label">{c.label}</span>
          </span>
        ))}
      </div>

      <div class="container hero-inner">
        <h1 class="hero-headline">
          We find the workflow. We <em>build the agent.</em>
        </h1>

        <p class="hero-sub">
          The audit picks the workflow your team does every week with the
          highest combined volume, repeatability, and ROI. Then the sprint
          ships an agent that reads your source docs, drafts the next step,
          and writes the output to the
          <strong>tools your team already uses</strong>.
        </p>

        <div class="hero-actions">
          <a class="btn btn-primary" href="#book">
            Book a free 30-min audit
            <svg class="btn-arrow" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 8h10M9 4l4 4-4 4"></path>
            </svg>
          </a>
          <a class="btn btn-ghost" href="#loom">Watch the 2-min demo</a>
        </div>

        <div class="hero-flow" aria-hidden="true">
          <div class="hero-flow-step hero-flow-step-1">
            <span class="hero-flow-icon">
              <svg viewBox="0 0 22 26" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3.5 1.5h11l4 4v18a1 1 0 0 1-1 1h-14a1 1 0 0 1-1-1V2.5a1 1 0 0 1 1-1z"/>
                <path d="M14.5 1.5v4h4"/>
                <path class="hero-flow-read-line hero-flow-read-line-1" d="M6 12.5h10"/>
                <path class="hero-flow-read-line hero-flow-read-line-2" d="M6 16.5h8"/>
                <path class="hero-flow-read-line hero-flow-read-line-3" d="M6 20.5h6"/>
              </svg>
            </span>
            <span class="hero-flow-label">Read</span>
          </div>
          <span class="hero-flow-connector hero-flow-connector-1"></span>
          <div class="hero-flow-step hero-flow-step-2">
            <span class="hero-flow-icon hero-flow-loader">
              <i></i><i></i><i></i>
            </span>
            <span class="hero-flow-label">Extract</span>
          </div>
          <span class="hero-flow-connector hero-flow-connector-2"></span>
          <div class="hero-flow-step hero-flow-step-3">
            <span class="hero-flow-icon">
              <svg viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1.5 11s3.5-7 9.5-7 9.5 7 9.5 7-3.5 7-9.5 7-9.5-7-9.5-7z"/>
                <circle class="hero-flow-review-pupil" cx="11" cy="11" r="3"/>
              </svg>
            </span>
            <span class="hero-flow-label">Review</span>
          </div>
          <span class="hero-flow-connector hero-flow-connector-3"></span>
          <div class="hero-flow-step hero-flow-step-4">
            <span class="hero-flow-icon">
              <svg viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="9"/>
                <path d="M6.5 11.5l3 3 6-6.5"/>
              </svg>
            </span>
            <span class="hero-flow-label">Deliver</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Who it's for / Problem · Fit -->
    <section class="section" id="who">
      <div class="container">
        <div class="section-head">
          <h2 class="section-title">Built for document-heavy teams.</h2>
          <p class="section-lede">
            If your team still reads PDFs by hand, copies fields into
            spreadsheets, rewrites the same responses, and hunts shared drives
            for source material — you don't need another AI app. You need one
            recurring workflow cleaned up, instrumented, and put under human
            control.
          </p>
        </div>

        <div class="segments">
          {segments.map((s, i) => (
            <div class="segment reveal" data-delay={(i % 4).toString()}>
              <span class="segment-num">{s.num}</span>
              <div>
                <h4>{s.title}</h4>
                <p>{s.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- What we build — the agents -->
    <section class="section" id="what" style="padding-top: 0;">
      <div class="container">
        <div class="section-head">
          <h2 class="section-title">Four agents already running in <em>production.</em></h2>
          <p class="section-lede">
            Each agent reads what it should read, drafts the next step, hands
            the decision to a human, and writes the result into the tool your
            team already uses. We ship one in your sprint, then expand from
            there.
          </p>
        </div>

        <div class="builds">
          {builds.map((b, i) => (
            <article class="build reveal" data-delay={(i % 4).toString()}>
              <div class={`agent-preview agent-preview-${b.kind}`} aria-hidden="true">
                {b.kind === "intake" && (
                  <div class="ap-intake">
                    <ul class="ap-intake-stack" role="list">
                      <li class="ap-intake-doc ap-id-1">
                        <span class="ap-intake-env" aria-hidden="true">
                          <svg viewBox="0 0 16 12" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="0.8" y="0.8" width="14.4" height="10.4" rx="1.2"/>
                            <path d="M1.4 1.8l6.6 5 6.6-5"/>
                          </svg>
                        </span>
                        <span class="ap-intake-name">invoice-04.pdf</span>
                        <span class="ap-intake-tag">Invoice</span>
                      </li>
                      <li class="ap-intake-doc ap-id-2">
                        <span class="ap-intake-env" aria-hidden="true">
                          <svg viewBox="0 0 16 12" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="0.8" y="0.8" width="14.4" height="10.4" rx="1.2"/>
                            <path d="M1.4 1.8l6.6 5 6.6-5"/>
                          </svg>
                        </span>
                        <span class="ap-intake-name">RFP-2026-0184.pdf</span>
                        <span class="ap-intake-tag">RFP</span>
                      </li>
                      <li class="ap-intake-doc ap-id-3">
                        <span class="ap-intake-env" aria-hidden="true">
                          <svg viewBox="0 0 16 12" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="0.8" y="0.8" width="14.4" height="10.4" rx="1.2"/>
                            <path d="M1.4 1.8l6.6 5 6.6-5"/>
                          </svg>
                        </span>
                        <span class="ap-intake-name">claim-018324.pdf</span>
                        <span class="ap-intake-tag">Claim</span>
                      </li>
                    </ul>
                    <div class="ap-intake-extract">
                      <div class="ap-intake-head">
                        <span><span class="ap-doc-tag-dot"></span>Extracted</span>
                        <span class="ap-intake-conf">Confidence</span>
                      </div>
                      <ul class="ap-intake-fields" role="list">
                        <li class="ap-intake-field ap-if-1">
                          <span class="ap-intake-flabel">Vendor</span>
                          <span class="ap-intake-fbar"><i style="--w:0.96"></i></span>
                        </li>
                        <li class="ap-intake-field ap-if-2">
                          <span class="ap-intake-flabel">Amount</span>
                          <span class="ap-intake-fbar"><i style="--w:0.92"></i></span>
                        </li>
                        <li class="ap-intake-field ap-if-3">
                          <span class="ap-intake-flabel">Due date</span>
                          <span class="ap-intake-fbar"><i style="--w:0.84"></i></span>
                        </li>
                        <li class="ap-intake-field ap-if-4">
                          <span class="ap-intake-flabel">PO #</span>
                          <span class="ap-intake-fbar"><i style="--w:0.54" data-low></i></span>
                        </li>
                      </ul>
                    </div>
                  </div>
                )}
                {b.kind === "rfp" && (
                  <div class="ap-rfp">
                    <div class="ap-doc">
                      <div class="ap-doc-head">
                        <span class="ap-doc-tag"><span class="ap-doc-tag-dot"></span>RFP-2026-0184.pdf</span>
                        <span class="ap-doc-status">L · M · C</span>
                      </div>
                      <div class="ap-doc-lines">
                        <span class="ap-line" style="--w:84%"></span>
                        <span class="ap-line is-hl is-hl-1" style="--w:72%"></span>
                        <span class="ap-line" style="--w:64%"></span>
                        <span class="ap-line is-hl is-hl-2" style="--w:78%"></span>
                        <span class="ap-line is-hl is-hl-3" style="--w:58%"></span>
                        <span class="ap-line" style="--w:42%"></span>
                      </div>
                    </div>
                  </div>
                )}
                {b.kind === "resume" && (
                  <div class="ap-resume">
                    <ul class="ap-resumes" role="list">
                      <li class="ap-resume-row ap-rr-1">
                        <span class="ap-avatar">JL</span>
