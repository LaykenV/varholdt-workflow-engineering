<script>
  // Nav scrolled state
  const nav = document.getElementById("site-nav");
  if (nav) {
    const onScroll = () => {
      if (window.scrollY > 20) nav.classList.add("scrolled");
      else nav.classList.remove("scrolled");
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  }

  // Hero is-ready (triggers demo entrance)
  const hero = document.querySelector<HTMLElement>("[data-hero]");
  if (hero) {
    window.setTimeout(() => hero.classList.add("is-ready"), 80);
  }

  // IntersectionObserver reveal
  const revealEls = document.querySelectorAll(".reveal");
  if ("IntersectionObserver" in window) {
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add("in");
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.1, rootMargin: "0px 0px -6% 0px" }
    );
    revealEls.forEach((el) => io.observe(el));
  } else {
    revealEls.forEach((el) => el.classList.add("in"));
  }

  // Pipeline active node cycle
  const pipeline = document.querySelector("[data-pipeline]");
  if (pipeline) {
    const nodes = Array.from(pipeline.querySelectorAll<HTMLElement>("[data-node-idx]"));
    let idx = 0;
    const setActive = (i: number) => {
      nodes.forEach((n, j) => n.classList.toggle("active", j === i));
    };
    setActive(0);
    window.setInterval(() => {
      idx = (idx + 1) % nodes.length;
      setActive(idx);
    }, 1800);
  }

  // KPI tickers — count up from 0 to target when first revealed
  const tickers = document.querySelectorAll<HTMLElement>("[data-ticker]");
  const animateTicker = (el: HTMLElement) => {
    const target = parseInt(el.getAttribute("data-target") || "0", 10);
    if (!target) return;
    const duration = 1400;
    const start = performance.now();
    const step = (now: number) => {
      const t = Math.min(1, (now - start) / duration);
      const eased = 1 - Math.pow(1 - t, 3);
      const val = Math.round(target * eased);
      el.textContent = String(val);
      if (t < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  };
  if ("IntersectionObserver" in window) {
    const tickIO = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            animateTicker(e.target as HTMLElement);
            tickIO.unobserve(e.target);
          }
        }
      },
      { threshold: 0.3 }
    );
    tickers.forEach((el) => tickIO.observe(el));
  } else {
    tickers.forEach((el) => animateTicker(el));
  }
</script>
